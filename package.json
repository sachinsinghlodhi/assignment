{
  "name": "fiber-challenge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development npx next dev --turbopack -p 3000",
    "build": "NODE_ENV=production npx next build --turbopack",
    "start": "NODE_ENV=production npx next start",
    "lint": "biome check",
    "format": "biome format --write",
    "setup": "npx tsx src/setup.ts",
    "test": "vitest run",
    "test:export": "npx tsx scripts/test-export-consistency.ts"
  },
  "type": "module",
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.575.0",
    "next": "15.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.20.4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
